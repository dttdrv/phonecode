<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup/transfer rules. Same exclusions as backup_rules.xml. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="phonecode_provider_keys.xml" />
        <exclude domain="file" path="workspace" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="phonecode_provider_keys.xml" />
    </device-transfer>
</data-extraction-rules>
